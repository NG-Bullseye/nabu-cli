#!/bin/bash
# NABU - CLI for Claude Chat Service
# Talks to claude-chat-service (POST /chat) with session continuity
# Usage: nabu "your message"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${NABU_CONFIG:-$SCRIPT_DIR/config}"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: config file not found at $CONFIG_FILE"
    echo "Run setup.sh first, or copy config.example to config."
    exit 1
fi

# shellcheck source=config.example
source "$CONFIG_FILE"

SESSION_FILE="$SCRIPT_DIR/.nabu_session_id"

# Colors
if [ -t 1 ]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
    BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; NC=''; BOLD=''
fi

show_usage() {
    cat << EOF
${BOLD}NABU - Claude Chat Service CLI${NC}

${BOLD}Usage:${NC}
  nabu "message"              Send message to Claude
  nabu --reset                Clear local session (start fresh)
  nabu --session              Show current session ID
  nabu --health               Check service health
  nabu --help                 Show this help

${BOLD}Options:${NC}
  --verbose                   Show full JSON response
  --help                      Show this help

${BOLD}Config:${NC}
  ${CONFIG_FILE}
  Service URL: ${CLAUDE_CHAT_URL}

EOF
}

get_session_id() {
    # Priority: config SESSION_ID > local session file
    if [ -n "${SESSION_ID:-}" ]; then
        echo "$SESSION_ID"
    elif [ -f "$SESSION_FILE" ]; then
        cat "$SESSION_FILE"
    else
        echo ""
    fi
}

save_session_id() {
    echo "$1" > "$SESSION_FILE"
}

reset_session() {
    if [ -f "$SESSION_FILE" ]; then
        rm "$SESSION_FILE"
        echo -e "${GREEN}✓${NC} Session cleared."
    else
        echo -e "${YELLOW}⚠${NC}  No local session to clear."
    fi
}

show_session() {
    local sid
    sid=$(get_session_id)
    if [ -n "$sid" ]; then
        echo -e "${CYAN}Session ID:${NC} ${BOLD}${sid}${NC}"
    else
        echo -e "${YELLOW}No active session.${NC} Next message will start a new one."
    fi
}

check_health() {
    echo -e "${CYAN}Checking ${CLAUDE_CHAT_URL}/health ...${NC}"
    local resp
    resp=$(curl -sf "${CLAUDE_CHAT_URL}/health" 2>&1) || {
        echo -e "${RED}✗ Service unreachable${NC}"
        exit 1
    }
    echo "$resp" | python3 -m json.tool 2>/dev/null || echo "$resp"
}

send_message() {
    local message="$1"
    local verbose="${2:-false}"

    local sid
    sid=$(get_session_id)

    # Build payload
    local payload
    payload=$(python3 -c "import json,sys; print(json.dumps({'prompt': sys.argv[1]}))" "$message")

    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}You:${NC} ${BOLD}${message}${NC}"
    if [ -n "$sid" ]; then
        echo -e "${CYAN}Session:${NC} ${sid}"
    fi
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    local response
    response=$(curl -s -X POST "${CLAUDE_CHAT_URL}/chat" \
        -H "Content-Type: application/json" \
        -d "$payload") || {
        echo -e "${RED}✗ Failed to reach service at ${CLAUDE_CHAT_URL}${NC}"
        exit 1
    }

    if [ "$verbose" = "true" ]; then
        echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
        echo ""
    fi

    local response_text new_sid
    response_text=$(echo "$response" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); print(d.get('response','(no response)'))" 2>/dev/null)
    new_sid=$(echo "$response" | python3 -c \
        "import sys,json; d=json.load(sys.stdin); print(d.get('session_id',''))" 2>/dev/null)

    echo -e "${GREEN}Claude:${NC} ${response_text}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    if [ -n "$new_sid" ]; then
        save_session_id "$new_sid"
        if [ "$new_sid" != "$sid" ]; then
            echo -e "${CYAN}Session:${NC} ${new_sid} (saved)"
        fi
    fi
}

main() {
    local message="" verbose=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --help|-h)    show_usage; exit 0 ;;
            --reset)      reset_session; exit 0 ;;
            --session)    show_session; exit 0 ;;
            --health)     check_health; exit 0 ;;
            --verbose|-v) verbose=true; shift ;;
            *)            message="${message:+$message }$1"; shift ;;
        esac
    done

    if [ -z "$message" ]; then
        echo -e "${RED}Error:${NC} No message provided."
        echo ""
        show_usage
        exit 1
    fi

    send_message "$message" "$verbose"
}

main "$@"
