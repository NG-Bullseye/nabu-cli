#!/bin/bash
# WORKER - tmux session manager for NABU
# Attaches to existing 'nabu' tmux session or creates a new one

SESSION_NAME="nabu"

if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    echo "Connecting to existing tmux session: $SESSION_NAME"
    tmux attach-session -t "$SESSION_NAME"
else
    echo "Creating new tmux session: $SESSION_NAME"
    tmux new-session -s "$SESSION_NAME"
fi
