#!/bin/bash
SESSION="worker"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${NABU_CONFIG:-$SCRIPT_DIR/config}"

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Error: config not found at $CONFIG_FILE"
    echo "Run setup.sh first, or copy config.example to config."
    exit 1
fi

source "$CONFIG_FILE"

# Already inside tmux → just run claude directly (avoid nested tmux)
if [ -n "$TMUX" ]; then
    cd "$WORK_DIR" && claude --resume "$WORKER_SESSION_ID"
    exit 0
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux attach-session -t "$SESSION"
else
    tmux new-session -s "$SESSION" -c "$WORK_DIR" \; send-keys "claude --resume $WORKER_SESSION_ID" Enter
fi
