# NABU Configuration
# Copy this file to 'config' and fill in your values:
#   cp config.example config

# Claude Chat Service URL (host running claude-chat-service)
# Local:  http://localhost:8765
# Remote: http://192.168.1.225:8765
CLAUDE_CHAT_URL="http://localhost:8765"

# Claude Code Session ID (for conversation continuity)
# Get current session from: curl http://<host>:8765/health
# Leave empty to start a new session
SESSION_ID=""
