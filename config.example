# nabu-cli Configuration
# Copy this file to 'config' and fill in your values:
#   cp config.example config

# Claude Code session ID for 'nabu' (nabu session)
NABU_SESSION_ID="your-session-id-here"

# Claude Code session ID for 'worker' (worker session)
WORKER_SESSION_ID="your-session-id-here"

# Working directory (where claude runs)
WORK_DIR="$HOME/homeassistant/_data"
