# NABU Configuration
# Copy this file to 'config' and fill in your values:
#   cp config.example config

# Home Assistant URL (e.g. http://localhost:8123 or https://your-ha.duckdns.org)
HA_URL="http://localhost:8123"

# Long-lived access token (HA → Profile → Long-Lived Access Tokens)
HA_TOKEN="your_token_here"

# Conversation Agent ID (HA → Settings → Voice Assistants → your agent)
AGENT_ID="your_agent_id_here"

# Default language for conversation
DEFAULT_LANGUAGE="de"
